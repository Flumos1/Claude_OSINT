{
  "buildCommand": "npm --prefix web/ui ci && npm --prefix web/ui run build",
  "outputDirectory": "web/static/dist",
  "functions": {
    "api/index.py": {
      "includeFiles": "{web,knowledge,scripts,cases,templates}/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
